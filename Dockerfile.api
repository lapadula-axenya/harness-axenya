FROM python:3.12-slim AS base

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1

WORKDIR /app

RUN pip install --no-cache-dir uv

COPY pyproject.toml ./
COPY src/ ./src/
COPY migrations/ ./migrations/
COPY agents/ ./agents/
COPY alembic.ini ./

RUN uv pip install --system --no-cache .

EXPOSE 8080

CMD ["uvicorn", "xenia.api.main:app", "--host", "0.0.0.0", "--port", "8080"]
