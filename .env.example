# Xenia Harness — environment variables (Phase 1)

# Database
DATABASE_URL=postgresql+asyncpg://xenia:xenia@localhost:5432/xenia
DATABASE_URL_SYNC=postgresql+psycopg://xenia:xenia@localhost:5432/xenia

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT (HS256). In prod this comes from Secret Manager.
JWT_SECRET=dev-only-not-for-prod-change-me
JWT_ALGORITHM=HS256

# LLM provider
ANTHROPIC_API_KEY=sk-ant-...
OMNIROUTER_API_KEY=
OMNIROUTER_BASE_URL=

# Webhook secrets (per-agent). Format: WEBHOOK_SECRET_<AGENT_ID_UPPER>
WEBHOOK_SECRET_EXEMPLO_ECO=dev-secret-exemplo-eco
WEBHOOK_SECRET_TRIAGEM_LEAD=dev-secret-triagem-lead

# Agent registry — directory containing YAML definitions
AGENTS_DIR=agents

# Service identity
SERVICE_NAME=xenia-api
LOG_LEVEL=INFO
ENV=dev

# Langfuse (Phase 4 — leave blank in dev to disable)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=

# ── Phase 3: external integrations ─────────────────────────────────────────
# Set the *_MCP_URL to switch the matching skill from mock to real MCP
# transport. Tokens go through Secret Manager in prod (GCP_PROJECT_ID) or
# env in dev.

# HubSpot
HUBSPOT_MCP_URL=
HUBSPOT_MCP_TOKEN=

# Slack
SLACK_MCP_URL=
SLACK_MCP_TOKEN=

# Jira / Atlassian
JIRA_MCP_URL=
JIRA_MCP_TOKEN=

# Ksenia (Axenya internal HTTP)
KSENIA_API_URL=
KSENIA_API_TOKEN=

# BigQuery — when set, bigquery.query runs against the live project; otherwise
# returns deterministic mock rows.
BIGQUERY_PROJECT_ID=

# GCP project for Secret Manager (prod). Leave blank in dev to use env vars.
GCP_PROJECT_ID=

# Enable Celery dispatch (Phase 2). 0 = in-process (dev), 1 = send to worker.
XENIA_USE_CELERY=0
