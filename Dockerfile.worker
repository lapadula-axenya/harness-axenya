FROM python:3.12-slim AS base

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1

WORKDIR /app

RUN pip install --no-cache-dir uv

COPY pyproject.toml ./
COPY src/ ./src/
COPY agents/ ./agents/

RUN uv pip install --system --no-cache .

CMD ["celery", "-A", "xenia.celery_app", "worker", "--queues=xenia", "--concurrency=4", "--loglevel=info"]
